+  read_socket_watcher_.StopWatchingFileDescriptor();
+  weak_factory_.InvalidateWeakPtrs();
+  std::move(read_if_ready_callback_).Run(
+      sel_result == 0 ? ERR_CONNECTION_TIMED_OUT : MapSystemError(errno));
