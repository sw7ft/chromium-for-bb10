+void SocketPosix::QnxReadSelectDone(int sel_result) {
+  if (read_if_ready_callback_.is_null())
+    return;
+
+  if (sel_result > 0) {
+    ReadCompleted();
+    return;
+  }
+
+  if (sel_result == 0) {
+    qnx_read_poll_count_++;
+    if (qnx_read_poll_count_ < 12) {
